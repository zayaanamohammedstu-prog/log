# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/

# Trained model files (generated at runtime; do not commit)
model/*.pkl
model/*.joblib
model/*.h5
models/*.pkl
models/*.joblib
models/*.h5
models/thresholds.json

# Generated evaluation outputs (produced at runtime)
data/processed/*.parquet
data/processed/*.csv
reports/*.png
reports/*.csv
metrics.csv

# Jupyter / EDA
.ipynb_checkpoints/
# Allow notebooks in the notebooks/ directory but ignore ad-hoc scratch notebooks
*.ipynb
!notebooks/*.ipynb

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# Editor / OS
.DS_Store
*.swp
*.idea/
.vscode/

# Flask instance folder (contains SQLite DB and local config)
instance/
